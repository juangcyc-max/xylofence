APP_NAME="Xylofence"
ENVIRONMENT=dev
DATABASE_URL=sqlite:///./xylofence.db
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Admin inicial (cámbialo antes de producción)
ADMIN_EMAIL=admin@xylofence.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FULL_NAME=Admin Xylofence

# CORS: lista separada por comas
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Sentinel — allowlist de hosts auditables (vacío = cualquiera autorizado)
ALLOWED_HOSTS=localhost,127.0.0.1
HTTP_TIMEOUT_SECONDS=8
MAX_REQUESTS_PER_SCAN=12
AUTO_CREATE_INCIDENTS=true
INCIDENT_MIN_SEVERITY=high

# Vultr Cloud Provider — generar en https://my.vultr.com/settings/#settingsapi
VULTR_API_KEY=

# Invitaciones
APP_BASE_URL=http://localhost:5173
INVITATION_EXPIRE_HOURS=72
